<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Repo-local feed config. Ignores machine-level sources (the private TitanSoft
    feed is only reachable on the corporate network) and restores from nuget.org
    plus the global package cache, so a clean checkout builds offline when the
    needed packages are already cached.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
